# Required: Railway PostgreSQL connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Required: long random authentication secret.
AUTH_TOKEN_SECRET="replace-with-a-long-random-secret"

AUTH_TOKEN_EXPIRES_SECONDS="86400"
NODE_ENV="production"
PORT="3000"
CORS_ORIGIN="https://your-frontend.vercel.app"
APP_NAME="Axtor POS Cloud API"

PLATFORM_ADMIN_EMAILS="platform-owner@example.com"

APP_VERSION="2026.07-global-saas"
SUPPORT_EMAIL="support@example.com"
SUPPORT_URL="https://example.com/support"

SEED_BUSINESS_NAME="Axtor Demo Business"
SEED_BUSINESS_SLUG="axtor-demo"
SEED_OWNER_NAME="Owner"
