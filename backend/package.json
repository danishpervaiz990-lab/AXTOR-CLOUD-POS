{
  "name": "axtor-pos-cloud-backend",
  "version": "0.1.0",
  "description": "Phase 2 backend/database foundation for Axtor POS Cloud.",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:predeploy": "prisma db execute --file prisma/predeploy-unique-indexes.sql --schema prisma/schema.prisma",
    "prisma:deploy": "npm run prisma:predeploy && prisma db push --skip-generate",
    "prisma:studio": "prisma studio",
    "seed:owner": "tsx src/scripts/seed-owner.ts"
    ,"seed:catalog": "tsx src/scripts/seed-commercial-catalog.ts"
    ,"release:deploy": "npm run prisma:deploy && npm run seed:catalog && npm run start"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "helmet": "8.1.0",
    "morgan": "1.10.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/morgan": "1.9.9",
    "@types/node": "22.15.3",
    "prisma": "6.19.0",
    "tsx": "4.19.4",
    "typescript": "5.8.3"
  }
}
