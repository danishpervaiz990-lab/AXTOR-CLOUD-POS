model Currency {
  code              String   @id
  name              String
  symbol            String
  decimalPrecision  Int      @default(2) @map("decimal_precision")
  symbolPosition    String   @default("before") @map("symbol_position")
  thousandSeparator String   @default(",") @map("thousand_separator")
  decimalSeparator  String   @default(".") @map("decimal_separator")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  businesses BusinessCurrency[]
  baseRates  ExchangeRate[]     @relation("ExchangeRateBase")
  quoteRates ExchangeRate[]     @relation("ExchangeRateQuote")

  @@index([active, name])
  @@map("currencies")
}

model BusinessCurrency {
  id           String   @id @default(cuid())
  businessId   String   @map("business_id")
  currencyCode String   @map("currency_code")
  isBase       Boolean  @default(false) @map("is_base")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  currency Currency @relation(fields: [currencyCode], references: [code], onDelete: Restrict)

  @@unique([businessId, currencyCode])
  @@index([businessId, isBase])
  @@map("business_currencies")
}

model ExchangeRate {
  id          String   @id @default(cuid())
  businessId  String?  @map("business_id")
  baseCode    String   @map("base_code")
  quoteCode   String   @map("quote_code")
  rate        Decimal  @db.Decimal(20, 8)
  source      String   @default("manual")
  effectiveAt DateTime @map("effective_at")
  createdAt   DateTime @default(now()) @map("created_at")

  business      Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  baseCurrency  Currency  @relation("ExchangeRateBase", fields: [baseCode], references: [code], onDelete: Restrict)
  quoteCurrency Currency  @relation("ExchangeRateQuote", fields: [quoteCode], references: [code], onDelete: Restrict)

  @@unique([businessId, baseCode, quoteCode, effectiveAt])
  @@index([businessId, baseCode, quoteCode, effectiveAt])
  @@map("exchange_rates")
}

model DocumentCurrencyRate {
  id               String   @id @default(cuid())
  businessId       String   @map("business_id")
  entityType       String   @map("entity_type")
  entityId         String   @map("entity_id")
  currencyCode     String   @map("currency_code")
  baseCurrencyCode String   @map("base_currency_code")
  rate             Decimal  @db.Decimal(20, 8)
  source           String   @default("manual")
  rateTimestamp    DateTime @map("rate_timestamp")
  createdAt        DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, entityType, entityId])
  @@index([businessId, currencyCode])
  @@map("document_currency_rates")
}

