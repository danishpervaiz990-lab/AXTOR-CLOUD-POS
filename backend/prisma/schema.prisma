  decisionNote      String?   @map("decision_note")
  decidedAt         DateTime? @map("decided_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, requestNo])
  @@index([businessId, status])
  @@map("approval_requests")
}

model CommunicationLog {
  id              String   @id @default(cuid())
  businessId      String   @map("business_id")
  customerId      String?  @map("customer_id")
  customerName    String?  @map("customer_name")
  type            String
  channel         String
  message         String
  status          String   @default("prepared")
  referenceNo     String?  @map("reference_no")
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([businessId, customerId])
  @@map("communication_logs")
}

model SubscriptionPlan {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  isRecommended Boolean  @default(false) @map("is_recommended")
  monthlyPrice  Decimal? @map("monthly_price") @db.Decimal(14, 2)
  annualPrice   Decimal? @map("annual_price") @db.Decimal(14, 2)
  priceCurrency String   @default("USD") @map("price_currency")
  maxUsers      Int?     @map("max_users")
  maxBranches   Int?     @map("max_branches")
  maxWarehouses Int?     @map("max_warehouses")
  maxCurrencies Int?     @map("max_currencies")
  maxLanguages  Int?     @map("max_languages")
  supportLevel  String   @default("email") @map("support_level")
  apiAccess     Boolean  @default(false) @map("api_access")
  whiteLabel    Boolean  @default(false) @map("white_label")
  active        Boolean  @default(true)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  features      PlanFeature[]
  subscriptions TenantSubscription[]
  invoices      SubscriptionInvoice[]

  @@index([active, sortOrder])
  @@map("subscription_plans")
}

model PlanFeature {
  id         String   @id @default(cuid())
  planId     String   @map("plan_id")
  featureKey String   @map("feature_key")
  enabled    Boolean  @default(true)
  limitValue Int?     @map("limit_value")
  config     Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([featureKey])
  @@map("plan_features")
}

model TenantSubscription {
  id                 String                   @id @default(cuid())
  businessId         String                   @map("business_id")
  planId             String                   @map("plan_id")
  status             TenantSubscriptionStatus @default(TRIAL)
  billingCycle       BillingCycle             @default(MONTHLY) @map("billing_cycle")
  startsAt           DateTime                 @default(now()) @map("starts_at")
  trialEndsAt        DateTime?                @map("trial_ends_at")
  currentPeriodStart DateTime?                @map("current_period_start")
  currentPeriodEnd   DateTime?                @map("current_period_end")
  graceEndsAt        DateTime?                @map("grace_ends_at")
  cancelledAt        DateTime?                @map("cancelled_at")
  isCurrent          Boolean                  @default(true) @map("is_current")
  provider           String                   @default("manual")
  providerReference  String?                  @map("provider_reference")
  customLimits       Json?                    @map("custom_limits")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([businessId, isCurrent, status])
  @@index([currentPeriodEnd])
  @@map("tenant_subscriptions")
}

model TenantFeatureOverride {
  id         String    @id @default(cuid())
  businessId String    @map("business_id")
  featureKey String    @map("feature_key")
  enabled    Boolean?
  limitValue Int?      @map("limit_value")
  reason     String?
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, featureKey])
  @@index([businessId, expiresAt])
  @@map("tenant_feature_overrides")
}

model UsageRecord {
  id          String   @id @default(cuid())
  businessId  String   @map("business_id")
  metricKey   String   @map("metric_key")
  quantity    Decimal  @default(0) @db.Decimal(18, 3)
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, metricKey, periodStart, periodEnd])
  @@index([businessId, metricKey])
  @@map("usage_records")
}

model SubscriptionInvoice {
  id         String    @id @default(cuid())
  businessId String    @map("business_id")
  planId     String    @map("plan_id")
  invoiceNo  String    @unique @map("invoice_no")
  status     String    @default("draft")
  currency   String    @default("USD")
  subtotal   Decimal   @default(0) @db.Decimal(14, 2)
  tax        Decimal   @default(0) @db.Decimal(14, 2)
  total      Decimal   @default(0) @db.Decimal(14, 2)
  dueAt      DateTime? @map("due_at")
  paidAt     DateTime? @map("paid_at")
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  business Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments SubscriptionPayment[]

  @@index([businessId, status])
  @@map("subscription_invoices")
}

model SubscriptionPayment {
  id                String    @id @default(cuid())
  businessId        String    @map("business_id")
  invoiceId         String?   @map("invoice_id")
  provider          String    @default("manual")
  providerReference String?   @map("provider_reference")
  status            String    @default("pending")
  currency          String    @default("USD")
  amount            Decimal   @default(0) @db.Decimal(14, 2)
  receivedAt        DateTime? @map("received_at")
  metadata          Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  business Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice  SubscriptionInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([businessId, status])
  @@map("subscription_payments")
}

model IndustryProfile {
