  @@unique([industryId, featureKey])
  @@map("industry_features")
}

model BusinessIndustry {
  id         String   @id @default(cuid())
  businessId String   @unique @map("business_id")
  industryId String   @map("industry_id")
  selectedAt DateTime @default(now()) @map("selected_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  industry IndustryProfile @relation(fields: [industryId], references: [id], onDelete: Restrict)

