generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BusinessStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum DocumentType {
  INVOICE
  QUOTATION
  DELIVERY_NOTE
}

enum SalesDocumentStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  CREDIT
  CANCELLED
  VOID
}

enum StockDirection {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

enum PurchaseStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum CounterStatus {
  ACTIVE
  INACTIVE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
  CUSTOM
}

enum TenantSubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum OnboardingState {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Business {
  id                    String          @id @default(cuid())
  name                  String
  legalName             String?         @map("legal_name")
  slug                  String          @unique
  status                BusinessStatus  @default(TRIAL)
  country               String?         @default("QA")
  timezone              String?         @default("Asia/Qatar")
  currency              String?         @default("QAR")
  taxNumber             String?         @map("tax_number")
  subscriptionPlan      String?         @map("subscription_plan")
  subscriptionStatus    String?         @map("subscription_status")
  trialEndsAt           DateTime?       @map("trial_ends_at")
  defaultLanguage       String          @default("en") @map("default_language")
  dateFormat            String          @default("yyyy-MM-dd") @map("date_format")
  numberLocale          String          @default("en-QA") @map("number_locale")
  taxLabel              String          @default("Tax") @map("tax_label")
  onboardingState       OnboardingState @default(NOT_STARTED) @map("onboarding_state")
  onboardingStep        Int             @default(1) @map("onboarding_step")
  onboardingCompletedAt DateTime?       @map("onboarding_completed_at")
  maintenanceMode       Boolean         @default(false) @map("maintenance_mode")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  users                 User[]
  roles                 Role[]
  userRoles             UserRole[]
  branches              Branch[]
  warehouses            Warehouse[]
  customers             Customer[]
  suppliers             Supplier[]
  productCategories     ProductCategory[]
  products              Product[]
  inventoryStocks       InventoryStock[]
  stockMovements        StockMovement[]
  salesDocuments        SalesDocument[]
  salesDocumentItems    SalesDocumentItem[]
  salesReturns          SalesReturn[]
  salesReturnItems      SalesReturnItem[]
  customerPayments      CustomerPayment[]
  customerRefunds       CustomerRefund[]
  purchases             Purchase[]
  purchaseItems         PurchaseItem[]
  supplierPayments      SupplierPayment[]
  accounts              Account[]
  expenses              Expense[]
  shifts                Shift[]
  counters              Counter[]
  auditLogs             AuditLog[]
  appSettings           AppSetting[]
  documentCounters      DocumentCounter[]
  salesmen              Salesman[]
  salesmanTargets       SalesmanTarget[]
  commissionPayouts     CommissionPayout[]
  stockCounts           StockCount[]
  stockCountItems       StockCountItem[]
  purchaseRequests      PurchaseRequest[]
  goodsReceipts         GoodsReceipt[]
  goodsReceiptItems     GoodsReceiptItem[]
  purchaseReturns       PurchaseReturn[]
  purchaseReturnItems   PurchaseReturnItem[]
  accountTransactions   AccountTransaction[]
  promotions            Promotion[]
  loyaltyPrograms       LoyaltyProgram[]
  loyaltyAccounts       LoyaltyAccount[]
  loyaltyLedgers        LoyaltyLedger[]
  notifications         Notification[]
  approvalRules         ApprovalRule[]
  approvalRequests      ApprovalRequest[]
  communicationLogs     CommunicationLog[]
  tenantSubscriptions   TenantSubscription[]
  featureOverrides      TenantFeatureOverride[]
  usageRecords          UsageRecord[]
  subscriptionInvoices  SubscriptionInvoice[]
  subscriptionPayments  SubscriptionPayment[]
  businessIndustry      BusinessIndustry?
  industrySettings      IndustrySetting[]
  businessCurrencies    BusinessCurrency[]
  exchangeRates         ExchangeRate[]
  documentCurrencyRates DocumentCurrencyRate[]
  locale                BusinessLocale?
  taxRates              TaxRate[]
  taxGroups             TaxGroup[]
  taxSetting            BusinessTaxSetting?
  onboarding            TenantOnboarding?
  authSessions          AuthSession[]
  importJobs            DataImportJob[]

  @@map("businesses")
}

model User {
  id                 String     @id @default(cuid())
  businessId         String     @map("business_id")
  branchId           String?    @map("branch_id")
  name               String
  email              String
  phone              String?
  passwordHash       String?    @map("password_hash")
  preferredLanguage  String?    @map("preferred_language")
  mustChangePassword Boolean    @default(false) @map("must_change_password")
  status             UserStatus @default(INVITED)
  lastLoginAt        DateTime?  @map("last_login_at")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  userRoles    UserRole[]
  authSessions AuthSession[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([branchId])
  @@map("users")
}

model Role {
  id           String   @id @default(cuid())
  businessId   String   @map("business_id")
  name         String
  description  String?
  isSystemRole Boolean  @default(false) @map("is_system_role")
  permissions  String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  business  Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userRoles UserRole[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("roles")
}

model UserRole {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  createdAt  DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId, roleId])
  @@index([businessId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Branch {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  name       String
  code       String?
  phone      String?
  address    String?
  city       String?
  country    String?  @default("QA")
  type       String?  @default("Retail")
  manager    String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  users      User[]
  warehouses Warehouse[]
  counters   Counter[]
  shifts     Shift[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("branches")
}

model Warehouse {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  branchId   String?  @map("branch_id")
  name       String
  code       String?
  address    String?
  mapUrl     String?  @map("map_url")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([businessId, name])
  @@index([businessId])
  @@index([branchId])
  @@map("warehouses")
}

model Customer {
  id                String   @id @default(cuid())
  businessId        String   @map("business_id")
  name              String
  code              String?
  company           String?
  phone             String?
  email             String?
  type              String?  @default("Retail")
  address           String?
  creditLimit       Decimal  @default(0) @map("credit_limit") @db.Decimal(14, 2)
  creditDays        Int      @default(30) @map("credit_days")
  openingBalance    Decimal  @default(0) @map("opening_balance") @db.Decimal(14, 2)
  balance           Decimal  @default(0) @db.Decimal(14, 2)
  status            String?  @default("active")
  preferredCurrency String?  @map("preferred_currency")
  taxExempt         Boolean  @default(false) @map("tax_exempt")
  active            Boolean  @default(true)
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, code])
  @@index([businessId])
  @@index([businessId, name])
  @@map("customers")
}

model Supplier {
  id                String   @id @default(cuid())
  businessId        String   @map("business_id")
  name              String
  company           String?
  phone             String?
  email             String?
  address           String?
  creditDays        Int      @default(30) @map("credit_days")
  openingBalance    Decimal  @default(0) @map("opening_balance") @db.Decimal(14, 2)
  balance           Decimal  @default(0) @db.Decimal(14, 2)
  preferredCurrency String?  @map("preferred_currency")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, name])
  @@map("suppliers")
}

model ProductCategory {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  name       String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@index([businessId])
  @@map("product_categories")
}

model Product {
  id           String   @id @default(cuid())
  businessId   String   @map("business_id")
  sku          String
  barcode      String?
  qrCode       String?  @map("qr_code")
  code         String?
  itemCode     String?  @map("item_code")
  productCode  String?  @map("product_code")
  name         String
  category     String?
  brand        String?
  unit         String?  @default("PCS")
  price        Decimal  @default(0) @db.Decimal(14, 2)
  costPrice    Decimal  @default(0) @map("cost_price") @db.Decimal(14, 2)
  minStock     Decimal  @default(0) @map("min_stock") @db.Decimal(14, 3)
  openingStock Decimal  @default(0) @map("opening_stock") @db.Decimal(14, 3)
  currentStock Decimal  @default(0) @map("current_stock") @db.Decimal(14, 3)
  deleted      Boolean  @default(false)
  active       Boolean  @default(true)
  imageUrl     String?  @map("image_url")
  customFields Json?    @map("custom_fields")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, sku])
  @@index([businessId])
  @@index([businessId, barcode])
  @@index([businessId, qrCode])
  @@map("products")
}

model InventoryStock {
  id           String   @id @default(cuid())
  businessId   String   @map("business_id")
  productId    String   @map("product_id")
  warehouseId  String   @map("warehouse_id")
  qtyOnHand    Decimal  @default(0) @map("qty_on_hand") @db.Decimal(14, 3)
  qtyReserved  Decimal  @default(0) @map("qty_reserved") @db.Decimal(14, 3)
  reorderLevel Decimal  @default(0) @map("reorder_level") @db.Decimal(14, 3)
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, productId, warehouseId])
  @@index([businessId])
  @@index([productId])
  @@index([warehouseId])
  @@map("inventory_stocks")
}

model StockMovement {
  id            String         @id @default(cuid())
  businessId    String         @map("business_id")
  movementNo    String         @map("movement_no")
  productId     String?        @map("product_id")
  sku           String?
  productName   String         @map("product_name")
  warehouseId   String?        @map("warehouse_id")
  toWarehouseId String?        @map("to_warehouse_id")
  direction     StockDirection
  movementType  String         @map("movement_type")
  referenceNo   String?        @map("reference_no")
  qty           Decimal        @db.Decimal(14, 3)
  beforeQty     Decimal?       @map("before_qty") @db.Decimal(14, 3)
  afterQty      Decimal?       @map("after_qty") @db.Decimal(14, 3)
  source        String?
  metadata      Json?
  movementDate  DateTime       @default(now()) @map("movement_date")
  createdAt     DateTime       @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, movementNo])
  @@index([businessId])
  @@index([businessId, sku])
  @@index([businessId, referenceNo])
  @@map("stock_movements")
}

model SalesDocument {
  id                    String              @id @default(cuid())
  businessId            String              @map("business_id")
  branchId              String?             @map("branch_id")
  warehouseId           String?             @map("warehouse_id")
  shiftId               String?             @map("shift_id")
  counterId             String?             @map("counter_id")
  documentNo            String              @map("document_no")
  documentType          DocumentType        @map("document_type")
  documentPrefix        String?             @map("document_prefix")
  lpoNo                 String?             @map("lpo_no")
  customerPoNo          String?             @map("customer_po_no")
  poNo                  String?             @map("po_no")
  customerId            String?             @map("customer_id")
  customerName          String              @map("customer_name")
  salesmanId            String?             @map("salesman_id")
  salesmanName          String?             @map("salesman_name")
  paymentMethod         String?             @map("payment_method")
  currency              String?             @default("QAR")
  exchangeRate          Decimal             @default(1) @map("exchange_rate") @db.Decimal(20, 8)
  exchangeRateSource    String              @default("manual") @map("exchange_rate_source")
  exchangeRateTimestamp DateTime?           @map("exchange_rate_timestamp")
  salesChannel          String?             @map("sales_channel")
  referenceNo           String?             @map("reference_no")
  internalNotes         String?             @map("internal_notes")
  customerNotes         String?             @map("customer_notes")
  paymentStatus         String?             @map("payment_status")
  stockStatus           String?             @map("stock_status")
  status                SalesDocumentStatus @default(DRAFT)
  subtotal              Decimal             @default(0) @db.Decimal(14, 2)
  discount              Decimal             @default(0) @db.Decimal(14, 2)
  tax                   Decimal             @default(0) @db.Decimal(14, 2)
  total                 Decimal             @default(0) @db.Decimal(14, 2)
  paid                  Decimal             @default(0) @db.Decimal(14, 2)
  balance               Decimal             @default(0) @db.Decimal(14, 2)
  baseSubtotal          Decimal             @default(0) @map("base_subtotal") @db.Decimal(14, 2)
  baseDiscount          Decimal             @default(0) @map("base_discount") @db.Decimal(14, 2)
  baseTax               Decimal             @default(0) @map("base_tax") @db.Decimal(14, 2)
  baseTotal             Decimal             @default(0) @map("base_total") @db.Decimal(14, 2)
  basePaid              Decimal             @default(0) @map("base_paid") @db.Decimal(14, 2)
  baseBalance           Decimal             @default(0) @map("base_balance") @db.Decimal(14, 2)
  returnStatus          String              @default("not_returned") @map("return_status")
  returnedAmount        Decimal             @default(0) @map("returned_amount") @db.Decimal(14, 2)
  returnCount           Int                 @default(0) @map("return_count")
  refundedAmount        Decimal             @default(0) @map("refunded_amount") @db.Decimal(14, 2)
  refundStatus          String              @default("not_refunded") @map("refund_status")
  creditAmount          Decimal             @default(0) @map("credit_amount") @db.Decimal(14, 2)
  customerCreditApplied Boolean             @default(false) @map("customer_credit_applied")
  dueDate               DateTime?           @map("due_date")
  issuedAt              DateTime?           @map("issued_at")
  postedAt              DateTime?           @map("posted_at")
  idempotencyKey        String?             @map("idempotency_key")
  createdByUserId       String?             @map("created_by_user_id")
  updatedByUserId       String?             @map("updated_by_user_id")
  revision              Int                 @default(1)
  metadata              Json?
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  business Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items    SalesDocumentItem[]
  returns  SalesReturn[]
  refunds  CustomerRefund[]

  @@unique([businessId, documentNo])
  @@unique([businessId, idempotencyKey])
  @@index([businessId])
  @@index([businessId, warehouseId])
  @@index([businessId, shiftId])
  @@index([businessId, counterId])
  @@index([businessId, referenceNo])
  @@index([businessId, documentType])
  @@index([businessId, customerId])
  @@index([businessId, status])
  @@map("sales_documents")
}

model SalesDocumentItem {
  id              String   @id @default(cuid())
  businessId      String   @map("business_id")
  salesDocumentId String   @map("sales_document_id")
  productId       String?  @map("product_id")
  sku             String?
  barcode         String?
  qrCode          String?  @map("qr_code")
  name            String
  description     String?
  unit            String?  @default("PCS")
  qty             Decimal  @db.Decimal(14, 3)
  rate            Decimal  @default(0) @db.Decimal(14, 2)
  price           Decimal  @default(0) @db.Decimal(14, 2)
  discount        Decimal  @default(0) @db.Decimal(14, 2)
  taxRate         Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  tax             Decimal  @default(0) @db.Decimal(14, 2)
  total           Decimal  @default(0) @db.Decimal(14, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  salesDocument SalesDocument @relation(fields: [salesDocumentId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([salesDocumentId])
  @@index([businessId, sku])
  @@map("sales_document_items")
}

model SalesReturn {
  id                    String   @id @default(cuid())
  businessId            String   @map("business_id")
  branchId              String?  @map("branch_id")
  returnNo              String   @map("return_no")
  sourceSalesDocumentId String   @map("source_sales_document_id")
  sourceDocumentNo      String?  @map("source_document_no")
  customerId            String?  @map("customer_id")
  customerName          String   @map("customer_name")
  reason                String?
  status                String   @default("POSTED")
  subtotal              Decimal  @default(0) @db.Decimal(14, 2)
  total                 Decimal  @default(0) @db.Decimal(14, 2)
  refundAmount          Decimal  @default(0) @map("refund_amount") @db.Decimal(14, 2)
  creditAmount          Decimal  @default(0) @map("credit_amount") @db.Decimal(14, 2)
  returnDate            DateTime @default(now()) @map("return_date")
  metadata              Json?
  idempotencyKey        String?  @map("idempotency_key")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  business            Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sourceSalesDocument SalesDocument     @relation(fields: [sourceSalesDocumentId], references: [id], onDelete: Cascade)
  items               SalesReturnItem[]
  refunds             CustomerRefund[]

  @@unique([businessId, returnNo])
  @@unique([businessId, idempotencyKey])
  @@index([businessId])
  @@index([businessId, sourceSalesDocumentId])
  @@index([businessId, customerId])
  @@map("sales_returns")
}

model SalesReturnItem {
  id            String   @id @default(cuid())
  businessId    String   @map("business_id")
  salesReturnId String   @map("sales_return_id")
  productId     String?  @map("product_id")
  sku           String?
  barcode       String?
  qrCode        String?  @map("qr_code")
  name          String
  unit          String?  @default("PCS")
  soldQty       Decimal  @default(0) @map("sold_qty") @db.Decimal(14, 3)
  returnQty     Decimal  @map("return_qty") @db.Decimal(14, 3)
  rate          Decimal  @default(0) @db.Decimal(14, 2)
  total         Decimal  @default(0) @db.Decimal(14, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  salesReturn SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([salesReturnId])
  @@index([businessId, sku])
  @@map("sales_return_items")
}

model CustomerRefund {
  id                    String    @id @default(cuid())
  businessId            String    @map("business_id")
  refundNo              String    @map("refund_no")
  salesDocumentId       String    @map("sales_document_id")
  salesReturnId         String?   @map("sales_return_id")
  customerId            String?   @map("customer_id")
  customerName          String    @map("customer_name")
  amount                Decimal   @db.Decimal(14, 2)
  currency              String    @default("QAR")
  exchangeRate          Decimal   @default(1) @map("exchange_rate") @db.Decimal(20, 8)
  baseAmount            Decimal   @default(0) @map("base_amount") @db.Decimal(14, 2)
  exchangeRateSource    String    @default("manual") @map("exchange_rate_source")
  exchangeRateTimestamp DateTime? @map("exchange_rate_timestamp")
  method                String
  accountId             String?   @map("account_id")
  referenceNo           String?   @map("reference_no")
  notes                 String?
  idempotencyKey        String?   @map("idempotency_key")
  refundDate            DateTime  @default(now()) @map("refund_date")
  metadata              Json?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  salesDocument SalesDocument @relation(fields: [salesDocumentId], references: [id], onDelete: Cascade)
  salesReturn   SalesReturn?  @relation(fields: [salesReturnId], references: [id], onDelete: SetNull)

  @@unique([businessId, refundNo])
  @@unique([businessId, idempotencyKey])
  @@index([businessId])
  @@index([businessId, salesDocumentId])
  @@index([businessId, salesReturnId])
  @@index([businessId, customerId])
  @@map("customer_refunds")
}

model CustomerPayment {
  id                    String    @id @default(cuid())
  businessId            String    @map("business_id")
  receiptNo             String    @map("receipt_no")
  customerId            String?   @map("customer_id")
  customerName          String    @map("customer_name")
  amount                Decimal   @db.Decimal(14, 2)
  currency              String    @default("QAR")
  exchangeRate          Decimal   @default(1) @map("exchange_rate") @db.Decimal(20, 8)
  baseAmount            Decimal   @default(0) @map("base_amount") @db.Decimal(14, 2)
  exchangeRateSource    String    @default("manual") @map("exchange_rate_source")
  exchangeRateTimestamp DateTime? @map("exchange_rate_timestamp")
  method                String?
  accountId             String?   @map("account_id")
  referenceNo           String?   @map("reference_no")
  idempotencyKey        String?   @map("idempotency_key")
  allocation            Json?
  paymentDate           DateTime  @default(now()) @map("payment_date")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, receiptNo])
  @@unique([businessId, idempotencyKey])
  @@index([businessId])
  @@index([businessId, customerId])
  @@map("customer_payments")
}

model Purchase {
  id                    String         @id @default(cuid())
  businessId            String         @map("business_id")
  branchId              String?        @map("branch_id")
  warehouseId           String?        @map("warehouse_id")
  purchaseNo            String         @map("purchase_no")
